# MongoDB Atlas (you already have this)
MONGODB_URI=your_mongodb_atlas_connection_string

# JWT secret - any long random string, used to sign login tokens
JWT_SECRET=replace_with_a_long_random_string

# Server port
PORT=3000

# Razorpay - sign up free at https://dashboard.razorpay.com/signup
# Use TEST mode keys (Settings > API Keys) - no real money needed for college project
RAZORPAY_KEY_ID=your_razorpay_test_key_id
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret

# No key needed for maps - we use free OpenStreetMap Nominatim for geocoding
